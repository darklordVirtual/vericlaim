{
  "name": "vericlaim-cloudflare-ai",
  "version": "0.2.0",
  "private": true,
  "description": "Optional Cloudflare Workers add-on for vericlaim: AI embedding + Vectorize search + MCP over your claim register.",
  "type": "module",
  "scripts": {
    "setup": "./setup.sh",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "create-index": "wrangler vectorize create vericlaim-claims --dimensions=768 --metric=cosine",
    "test": "node --experimental-strip-types --test test/authz.test.ts",
    "test:live": "python3 test/live_test.py"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.23.0",
    "agents": "^0.2.35",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
